{
  "name": "nuxt-colorway-starter",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "dev": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp nuxt dev",
    "dev:e2e": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp nuxt dev --host 127.0.0.1 --port 3100",
    "build": "nuxt build",
    "start": "NODE_ENV=production node .output/server/index.mjs",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:boundaries": "node scripts/check-ai-boundaries.mjs",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "pnpm check:boundaries && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:e2e": "pnpm test:e2e",
    "verify:docker": "docker build -t nuxt-starter .",
    "verify:full": "pnpm verify && pnpm verify:e2e && pnpm verify:docker"
  },
  "dependencies": {
    "@lucide/vue": "1.17.0",
    "@tanstack/vue-query": "5.101.0",
    "@vee-validate/zod": "4.15.1",
    "@vueuse/core": "14.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "nuxt": "4.4.8",
    "reka-ui": "2.9.10",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "vee-validate": "4.15.1",
    "vue": "3.5.38",
    "vue-sonner": "2.0.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "@nuxt/eslint": "1.16.0",
    "@nuxtjs/i18n": "10.4.0",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.0",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.4.1",
    "happy-dom": "20.10.2",
    "shadcn-nuxt": "2.7.4",
    "shadcn-vue": "2.7.4",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.4"
  }
}
